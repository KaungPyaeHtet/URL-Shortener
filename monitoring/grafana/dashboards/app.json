        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (instance) / sum(rate(http_requests_total[5m])) by (instance)",
          "legendFormat": "{{ instance }} — 5xx rate",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{status=~\"4..\"}[5m])) by (instance) / sum(rate(http_requests_total[5m])) by (instance)",
          "legendFormat": "{{ instance }} — 4xx rate",
          "refId": "B"
        }
      ],
      "title": "Error Rate (4xx / 5xx)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
